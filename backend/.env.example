# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@TU_CLUSTER.mongodb.net/bakery_db?retryWrites=true&w=majority

# ─── Appwrite (para verificar JWTs en el backend) ─────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=TU_PROJECT_ID_AQUI
APPWRITE_API_KEY=TU_API_KEY_AQUI

# ─── Supabase (solo necesario para el script de migración) ───────────────────
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=TU_SERVICE_ROLE_KEY_AQUI

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
